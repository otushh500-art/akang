# ═══════════════════════════════════════════════════════════════════════════
# RubyMine — PRODUCTION Environment Variables
# Copy to .env and fill in REAL values. Never commit this file.
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
TESTING=false
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
JWT_SECRET=CHANGE_ME_different_from_SECRET_KEY

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rubymine:CHANGE_ME@rubymine-postgres:5432/rubymine
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@rubymine-redis:6379/0
ARQ_REDIS_URL=redis://:CHANGE_ME@rubymine-redis:6379/1
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:CHANGE_ME
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBAPP_URL=https://t.me/your_bot/app
TELEGRAM_ADMIN_IDS=123456789
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_random_hex

# ── CORS / Frontend ─────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com,https://t.me

# ── CDN / Assets ────────────────────────────────────────────────────────────
CDN_BASE_URL=https://cdn.your-domain.com
UPLOAD_ROOT=uploads

# ── Payment providers ───────────────────────────────────────────────────────
PAYME_SECRET_KEY=CHANGE_ME
CLICK_SECRET_KEY=CHANGE_ME

# ── Rate limits ─────────────────────────────────────────────────────────────
CASE_OPEN_RATE_LIMIT=10/minute
BATTLE_CREATE_RATE_LIMIT=5/minute
BATTLE_ACTION_RATE_LIMIT=30/minute
AUTH_TELEGRAM_RATE_LIMIT=10/minute

# ── Economy ─────────────────────────────────────────────────────────────────
GLOBAL_RTP_TARGET=75
RECOVERY_THRESHOLD=-1000000

# ── Security ────────────────────────────────────────────────────────────────
USER_RISK_HIGH_THRESHOLD=75.0
# ADMIN_IP_WHITELIST=10.0.0.1,10.0.0.2,203.0.113.5  # comma-sep IPs; empty = allow any IP

# ── Docker image ────────────────────────────────────────────────────────────
DOCKER_IMAGE=rubymine-api
VERSION=latest

# ── API Docs (MUST be false in production) ──────────────────────────────────
ENABLE_API_DOCS=false

# ── Crypto wallets ──────────────────────────────────────────────────────────
CRYPTO_WALLET_TRC20=CHANGE_ME
CRYPTO_WALLET_TON=CHANGE_ME
CRYPTO_WALLET_ERC20=CHANGE_ME

# ── Payme / Click (optional) ─────────────────────────────────────────────────
PAYME_MERCHANT_ID=CHANGE_ME
PAYME_SECRET_KEY=CHANGE_ME
CLICK_MERCHANT_ID=CHANGE_ME
CLICK_SECRET_KEY=CHANGE_ME
