# ═══════════════════════════════════════════════════════════════════════════
# RubyMine Backend — Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────
APP_ENV=production                             # production | staging | development
DEBUG=false
SECRET_KEY=CHANGE_ME_min_32_chars_random_hex  # openssl rand -hex 32

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rubymine
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
# For local dev with SQLite (testing only):
# DATABASE_URL=sqlite+aiosqlite:///./rubymine_dev.db

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_redis_password
# With password:
# REDIS_URL=redis://:your_password@localhost:6379/0

# ── Telegram Bot ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_WEBAPP_URL=https://t.me/your_bot/app
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_random_secret

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-frontend.com,https://staging.your-frontend.com

# ── Asset / CDN ────────────────────────────────────────────────────────────
CDN_BASE_URL=https://cdn.your-domain.com
UPLOAD_ROOT=uploads                            # local path for skin assets

# ── Rate Limits ────────────────────────────────────────────────────────────
CASE_OPEN_RATE_LIMIT=10/minute
BATTLE_CREATE_RATE_LIMIT=5/minute
BATTLE_ACTION_RATE_LIMIT=30/minute

# ── Economy ────────────────────────────────────────────────────────────────
GLOBAL_RTP_TARGET=75                           # Target RTP %
RECOVERY_THRESHOLD=-1000000                    # Profit below this triggers recovery

# ── Payment Providers ──────────────────────────────────────────────────────
# Set secrets for each provider you use
PAYME_SECRET_KEY=CHANGE_ME
PAYME_MERCHANT_ID=CHANGE_ME
CLICK_SECRET_KEY=CHANGE_ME
CLICK_MERCHANT_ID=CHANGE_ME

# ── Crypto wallets (USDT) ──────────────────────────────────────────────────
# Set these before enabling the CRYPTO payment provider.
# Leave empty to keep crypto payments disabled (returns HTTP 503).
CRYPTO_WALLET_TRC20=                           # Your USDT TRC20 (Tron) address
CRYPTO_WALLET_TON=                             # Your USDT TON address
CRYPTO_WALLET_ERC20=                           # Your USDT ERC20 (Ethereum) address
WEBHOOK_MAX_TIMESTAMP_DRIFT=300                # seconds

# ── Admin ──────────────────────────────────────────────────────────────────
# Admin users are set via DB (is_admin=True). No env config needed.
# ADMIN_IP_WHITELIST=10.0.0.1,10.0.0.2,203.0.113.5  # comma-sep IPs; empty = allow any IP

# ── Battle Pass / Creator ──────────────────────────────────────────────────
CREATOR_DEFAULT_COMMISSION_PCT=5.0
CREATOR_MIN_REFERRALS_FOR_PAYOUT=10

# ── Security ───────────────────────────────────────────────────────────────
USER_RISK_HIGH_THRESHOLD=75.0
REFERRAL_LOCK_TTL=30

# ── Image Processing ───────────────────────────────────────────────────────
SKIN_IMAGE_MAX_BYTES=8388608                   # 8 MB
SKIN_THUMB_SIZES=512,256,128,64
SKIN_WEBP_QUALITY=85

# ── Worker ─────────────────────────────────────────────────────────────────
# ARQ workers pick up REDIS_URL automatically.
# Start workers with:
#   arq app.workers.economy_worker.WorkerSettings
#   arq app.workers.payment_worker.WorkerSettings
#   arq app.workers.security_worker.WorkerSettings
#   arq app.workers.admin_worker.WorkerSettings
#   arq app.workers.asset_worker.WorkerSettings
#   arq app.workers.creator_worker.WorkerSettings
#   arq app.workers.user_control_worker.WorkerSettings
#   arq app.workers.battle_cleanup_worker.WorkerSettings
#   arq app.workers.notification_worker.WorkerSettings

# ── API Docs ────────────────────────────────────────────────────────────────
# MUST be "false" in production. Set to "true" only in dev environment.
ENABLE_API_DOCS=false
